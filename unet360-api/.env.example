# ── MongoDB local (contenedor `mongo` de docker-compose) ──
# Credenciales del root que crea el contenedor de Mongo en el primer arranque.
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=
# Puerto del host mapeado al 27017 del contenedor (opcional, por defecto 27017).
MONGO_PORT=27017
# El host debe ser el nombre del servicio de compose (`mongo`) y authSource=admin.
# Ej: mongodb://<usuario>:<password>@mongo:27017/?authSource=admin
MONGODB_URL=
MONGODB_DB=

SUPABASE_URL=
SUPABASE_KEY=
DEBUG=
LOCAL_BUCKET_PATH=
INTERNAL_BUCKET_PATH=
PORT=
